# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/afridollar?schema=public"

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
# Window duration in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window for general API endpoints (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window for auth endpoints — stricter (default: 20)
RATE_LIMIT_AUTH_MAX_REQUESTS=20
# Max requests per window for admin endpoints — more permissive (default: 200)
RATE_LIMIT_ADMIN_MAX_REQUESTS=200
