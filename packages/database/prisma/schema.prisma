// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  BUSINESS
  ADMIN
  AUDITOR
}

enum UserStatus {
  active
  suspended
  banned
}

enum ComplianceAlertStatus {
  open
  resolved
  dismissed
}

enum JobExecutionStatus {
  pending
  running
  completed
  failed
}

enum ReportType {
  transaction_history
  compliance_report
  financial_statement
  payroll_report
  treasury_report
  audit_log
}

enum ReportFormat {
  csv
  pdf
  xlsx
}

enum ReportStatus {
  pending
  generating
  completed
  failed
}

// User model for authentication and authorization
model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String?
  phoneNumber   String?     @unique
  walletAddress String?     @unique
  firstName     String?
  lastName      String?
  role          UserRole    @default(USER)
  status        UserStatus  @default(active)
  isVerified    Boolean     @default(false)
  isActive      Boolean     @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  business          Business?
  wallets           Wallet[]
  transactions      Transaction[]
  kycRecords        KYCRecord[]
  refreshTokens     RefreshToken[]
  reportRequests    ReportRequest[]
  complianceAlerts  ComplianceAlert[]

  @@index([email])
  @@index([walletAddress])
  @@index([status])
}

// Business model for enterprise customers
model Business {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName     String
  businessType     String
  registrationNumber String?
  taxId           String?
  
  country         String
  region          String?
  city            String?
  address         String?
  
  isKycVerified   Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([businessName])
}

// Wallet model for Stellar wallets
model Wallet {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  publicKey       String   @unique
  secretKeyEncrypted String
  
  walletType      String   // 'business', 'treasury', 'payroll'
  network         String   @default("testnet") // 'testnet', 'mainnet'
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  balances        WalletBalance[]
  transactions    Transaction[]
  payrollBatches  PayrollBatch[]

  @@index([userId])
  @@index([publicKey])
}

// Wallet balance tracking for different assets
model WalletBalance {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  assetCode   String   // 'USDC', 'NGN', 'KES', etc.
  assetIssuer String?  // Stellar asset issuer
  balance     String   // Stored as string to handle precision
  updatedAt   DateTime @updatedAt

  @@unique([walletId, assetCode, assetIssuer])
  @@index([walletId])
}

// Transaction model for all transactions
model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  type            String   // 'deposit', 'withdrawal', 'transfer', 'exchange', 'payroll'
  status          String   @default("pending") // 'pending', 'completed', 'failed', 'cancelled'
  
  amount          String
  assetCode       String
  assetIssuer     String?
  
  fromAddress     String?
  toAddress       String?
  stellarTxId     String?  @unique
  
  metadata        Json?
  errorMessage    String?
  isFlagged       Boolean  @default(false)
  flagReason      String?
  flaggedAt       DateTime?
  flaggedBy       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  complianceAlerts ComplianceAlert[]

  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@index([stellarTxId])
  @@index([isFlagged])
}

// KYC records for compliance
model KYCRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider    String   // 'onfido', 'sumsub', etc.
  providerId  String?  // External provider's ID
  
  status      String   @default("pending") // 'pending', 'approved', 'rejected', 'review'
  
  documentType String?
  documentNumber String?
  
  metadata        Json?
  reviewedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Exchange rates for FX operations
model ExchangeRate {
  id          String   @id @default(cuid())
  
  fromAsset   String   // 'USDC'
  toAsset     String   // 'NGN'
  
  rate        String   // Stored as string for precision
  source      String   // 'internal', 'external', 'manual'
  
  isActive    Boolean  @default(true)
  validFrom   DateTime @default(now())
  validUntil  DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([fromAsset, toAsset, validFrom])
  @@index([fromAsset, toAsset])
  @@index([isActive])
}

// Persisted FX quotes for conversion execution
model ConversionQuote {
  id          String   @id @default(cuid())
  quoteId     String   @unique

  fromAsset   String
  toAsset     String
  fromAmount  String
  toAmount    String
  rate        String
  source      String

  walletId    String?
  status      String   @default("pending") // 'pending', 'executed', 'expired'
  expiresAt   DateTime
  executedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
  @@index([status, expiresAt])
  @@index([fromAsset, toAsset])
}

// Refresh tokens for JWT authentication
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tokenHash  String   @unique
  deviceInfo String?  // Stores user-agent or device fingerprint for device-scoped tokens
  isRevoked  Boolean  @default(false)
  revokedAt  DateTime?
  expiresAt  DateTime
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, deviceInfo])
}

// Audit log for compliance and security
model AuditLog {
  id          String   @id @default(cuid())
  
  userId      String?
  action      String   // 'login', 'wallet_create', 'transaction_init', etc.
  resource    String   // 'user', 'wallet', 'transaction', etc.
  resourceId  String?
  
  ipAddress   String?
  userAgent   String?
  
  metadata    Json?
  success     Boolean  @default(true)
  
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

// Scheduled job execution log
model JobExecution {
  id          String             @id @default(cuid())
  jobName     String
  status      JobExecutionStatus @default(pending)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([jobName, createdAt])
  @@index([status])
}

// Payroll batch for managing multiple payroll payouts
model PayrollBatch {
  id          String   @id @default(cuid())
  name        String
  description String?
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // 'pending', 'approved', 'processing', 'completed', 'failed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       PayrollItem[]

  @@index([walletId])
  @@index([status])
}

// Individual payment item in a payroll batch
model PayrollItem {
  id               String       @id @default(cuid())
  payrollBatchId   String
  payrollBatch     PayrollBatch @relation(fields: [payrollBatchId], references: [id], onDelete: Cascade)
  recipientAddress String
  amount           String
  assetCode        String
  assetIssuer      String?
  memo             String?
  status           String       @default("pending") // 'pending', 'processing', 'completed', 'failed'
  stellarTxId      String?
  errorMessage     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([payrollBatchId])
  @@index([status])
}

// Report generation and scheduling
model ReportRequest {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportType      ReportType
  format          ReportFormat
  parameters      Json?
  status          ReportStatus  @default(pending)
  downloadUrl     String?
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([userId])
}

model ReportTemplate {
  id              String        @id @default(cuid())
  name            String
  reportType      ReportType
  query           String?
  config          Json?
  format          ReportFormat
  schedule        String?

  @@index([reportType])
}

// Compliance alerts for admin dashboard monitoring
model ComplianceAlert {
  id              String                @id @default(cuid())
  type            String                // 'kyc', 'sanctions', 'travel_rule', 'aml', etc.
  severity        String                @default("medium") // 'low', 'medium', 'high', 'critical'
  status          ComplianceAlertStatus @default(open)
  title           String
  description     String?
  userId          String?
  user            User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactionId   String?
  transaction     Transaction?          @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  metadata        Json?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNote  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([userId])
  @@index([transactionId])
  @@index([createdAt])
}

// Platform configuration key/value store
model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}